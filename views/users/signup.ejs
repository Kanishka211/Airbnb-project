<%layout("/layouts/boilerplate")-%>

<div class="row mt-3">
    <h2 class="col-6 offset-3">SignUp for Dune-Delight</h2>
    <div class="col-6 offset-3">
       <form method="post" action="/signup"  class="needs-validation" novalidate>
         <div class="mb-3">
            <label for="username" class="form-label" >Username:</label>
            <input 
            type="text"
            name="username"
            id="username"
            placeholder="Enter username"
             
             class="form-control"
             required>
             <div class="valid-feedback">Looks good!</div>
          </div>
        <div  class="mb-3">
             <label for="email" class="form-label">Email:</label>
            <input type="text" name="email" id="email" placeholder="abc@gmail.com" class="form-control" required>
            <div class="invalid-feedback">Enter a valid email</div>
        </div>
        <div  class="mb-3">
             <label for="password" class="form-label">Password:</label>
            <input type="password" name="password" id="password" placeholder="Enter password" class="form-control" required>
            <div class="invalid-feedback">Enter a valid password</div>
            </div>
            <button type="submit" class="btn btn-sm btn-outline-success">SignUp</button>
       </form>
    </div>
</div>